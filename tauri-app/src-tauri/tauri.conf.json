{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixiv Platform",
  "version": "1.2.0",
  "identifier": "local.pixiv-platform.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd --prefix ../src/frontend run dev",
    "devUrl": "http://127.0.0.1:3001",
    "beforeBuildCommand": "scripts\\build-frontend-windows.cmd",
    "frontendDist": "../../src/frontend/out"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
